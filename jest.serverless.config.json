{
  "displayName": "Serverless API Tests",
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": "./src",
  "testMatch": [
    "**/tests/**/*.test.ts"
  ],
  "collectCoverageFrom": [
    "**/*.ts",
    "!**/tests/**",
    "!**/node_modules/**"
  ],
  "moduleNameMapping": {
    "^@/(.*)$": "<rootDir>/$1"
  },
  "setupFilesAfterEnv": ["<rootDir>/tests/setup.ts"],
  "coverageReporters": ["text", "lcov", "html"],
  "coverageDirectory": "../coverage-serverless"
}